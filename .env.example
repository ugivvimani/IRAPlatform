APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000

# Azure observability and secrets
APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_KEY_VAULT_URL=

# Azure WebJobs queue integration
AZURE_STORAGE_CONNECTION_STRING=
AZURE_WEBJOBS_ASSESSMENT_QUEUE=assessment-jobs

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported values: openrouter | openai | azure_openai | stub
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini

# OpenRouter (current provider)
OPENROUTER_API_KEY=

# OpenAI direct (used for embeddings; also fallback if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI (set LLM_PROVIDER=azure_openai to activate)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_TYPE=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector store ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=ira-platform-memory
PINECONE_NAMESPACE=default

# ── Live connectors ───────────────────────────────────────────────────────────
ENABLE_LIVE_CONNECTORS=true
OPENSANCTIONS_API_KEY=
NEWS_API_KEY=
SEC_CONTACT_EMAIL=
ESG_API_KEY=
CONNECTOR_TIMEOUT_SECONDS=20
CONNECTOR_MAX_RETRIES=2
CONNECTOR_RETRY_BACKOFF=1.5

# ── Persistence ───────────────────────────────────────────────────────────────
DB_BACKEND=sqlite
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/ira_platform
SQLITE_DB_PATH=data/ira_platform.db
